# Deployment name (used for resource naming — lowercase, no spaces)
name = "mycompany"

# AWS region
region = "us-east-1"

# Instance size (t3.medium minimum, t3.large recommended, t3.xlarge for heavy usage)
instance_type = "t3.large"

# Domain (optional — leave empty to access via IP over HTTP)
# If set, the deploy script will configure HTTPS with Let's Encrypt.
# DNS must be managed in Route53 for automatic record creation.
domain          = ""
route53_zone_id = ""

# Git ref to deploy (branch, tag, or commit SHA)
observal_ref = "main"

# VPC (optional — leave empty for default VPC)
# vpc_id    = "vpc-0123456789abcdef0"
# subnet_id = "subnet-0123456789abcdef0"
