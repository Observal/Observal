      "criticality": "critical",
      "source": "repository",
      "confidence": "high",
      "relevance_reason": "Primary operator of the audited surface"
    },
    {
      "id": "reviewer",
      "goal": "Review registry submissions without executive org analytics",
      "authority": "UserRole.reviewer; _admin layout RoleGuard minRole=reviewer",
      "entry_path": "Login \u2192 Review; may deep-link /dashboard because layout guard is reviewer-scoped",
