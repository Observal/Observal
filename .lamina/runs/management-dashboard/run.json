{
  "contract_version": "2.0",
  "id": "management-dashboard",
  "status": "complete",
  "stage": "shape",
  "hook": "audit",
  "target": "management-dashboard",
  "intent": {
    "problem": "Audit the management dashboard for empty states, failure recovery, permission boundaries, and admin task success",
    "outcome": "Platform admins can govern registry and ops from the management dashboard with clear empty/failure/permission states",
    "users": [
      "platform-admin"
    ],
    "critical_promises": [
      {
        "id": "admin-only-access",
        "promise": "Only admin-tier actors can reach and load Executive Dashboard metrics; denied actors get an explicit permission outcome",
        "criticality": "critical",
        "source": "repository",
        "confidence": "high",
        "relevance_reason": "Exec APIs require admin; nav hides Dashboard from non-admins; mismatch with page guard is in scope"
      },
      {
        "id": "honest-empty-setup",
        "promise": "When adoption/cost/department data is missing, the dashboard shows actionable empty or setup guidance that routes to reachable admin surfaces",
        "criticality": "critical",
        "source": "repository",
        "confidence": "high",
        "relevance_reason": "Onboarding wizard and per-tab empty states are the primary first-run admin experience"
      },
      {
        "id": "recoverable-load-failures",
        "promise": "When exec metrics fail to load, admins see an accurate failure reason and a reachable recovery path",
        "criticality": "critical",
        "source": "repository",
        "confidence": "high",
        "relevance_reason": "Every major tab implements isError branches; audit targets failure recovery"
      }
    ],
    "success_signals": [
      "Admin can open /dashboard and see Adoption KPIs or honest empty guidance",
      "Non-admin cannot load exec metrics as if authorized",
      "Failed fetches offer retry or refresh without blaming the wrong cause"
    ],
    "constraints": [
      "Grounding mode: static UI/API source (live authenticated dashboard not available in this session)",
      "Full-flow UX lenses applied; no lens truncation"
    ],
    "scope": {
      "in": [
        "Route /dashboard under _authed/_admin",
        "Executive Dashboard tabs: adoption, cost, investments, insights, departments, velocity",
        "Sidebar Admin > Dashboard entry",
        "Exec API permission boundary"
      ],
      "out": [
        "Registry home metrics unrelated to exec dashboard",
        "CLI ops overview",
        "Implementing product fixes in this turn"
      ]
    }
  },
  "decisions": {
    "assumptions": [
      {
        "id": "static-grounding",
        "class": "evidence_backed",
        "source": "repository",
        "confidence": "high",
        "statement": "Audit is grounded in web/src pages/admin/dashboard and observal-server exec_dashboard routes because no authenticated live UI was available"
      }
    ],
    "forks": []
  },
  "actors": [
    {
      "id": "platform-admin",
      "goal": "Govern org AI adoption, cost, and insights from the Executive Dashboard",
      "authority": "Server-side UserRole.admin (or super_admin) via require_role on /api/v1/exec/*; client role from auth profile",
